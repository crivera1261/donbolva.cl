---
import Header from "@components/common/header.astro";
import Footer from "@components/common/footer.astro";
import EntryModal from "@components/modal/EntryModal.astro";
const title =
  "La despensa de Don bolva";
const description =
  "Compra huevos frescos al por mayor. Huevos Organicos. Calidad garantizada, entrega rápida. Contacta con nosotros para obtener la mejor oferta. Canastas de verduras, frutas y más.";
const keywords =
  "huevos al por mayor, venta de huevos, huevos frescos, Canastas de verduras, verduras, frutas, compra, retiro en tienda,distribución de huevos, huevos La Serena, Coquimbo, Ovalle.";
const author = "LA DESPENSA DE DON BOLVA";
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width" />
    <link rel="icon" type="image/svg+xml" href="/favicon2.png" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Fraunces:ital,opsz,wght@0,9..144,100..900;1,9..144,100..900&family=Instrument+Sans:ital,wght@0,400..700;1,400..700&display=swap"
      rel="stylesheet"
    />
    <title>{title}</title>
    <meta name="description" content={description} />
    <meta name="keywords" content={keywords} />
    <meta name="author" content={author} />
    <!-- Open Graph para Facebook / LinkedIn -->
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />
    <meta property="og:image" content="/logo.png" />
    <meta property="og:url" content="https://donbolva.cl/" />

    <!-- Twitter Card -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content="/logo.png" />
  </head>
  <body class="font-sans min-h-dvh bg-cream">
    <slot />
    <!-- <Footer/> -->
  </body>
</html>