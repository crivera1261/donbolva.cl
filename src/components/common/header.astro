---
import { Image } from "astro:assets";
import logo2 from "@assets/logo2.png";
import wsp from "@assets/icons/whatsapp.svg";
import instagram from "@assets/icons/instagram.svg";
import map from "@assets/icons/map.svg";
---

<header
  class="flex bg-cream justify-between items-center w-full h-18 sm:h-20 px-4 sm:px-10 lg:px-18"
>
  <!-- logo -->
  <div class="flex items-center">
    <a href="/">
      <Image
        alt="logo"
        src={logo2}
        width="400"
        height="200"
        decoding="async"
        loading="eager"
        fetchpriority="high"
        class="h-auto w-24 sm:w-28 object-contain"
      />
    </a>
  </div>
  <!-- Acciones -->
  <div class="flex items-center gap-1 sm:gap-2">
    <div class="py-2 px-1 sm:py-4 sm:px-2">
      <a
        href="https://www.instagram.com/donbolva_distribuidora?igsh=Z3hqMzc5bXZxNjA1"
        target="_blank"
        class="flex flex-col justify-center items-center cursor-pointer"
        style="color: #432918"
      >
        <Image
          src={instagram}
          alt="Instagram"
          width={24}
          height={24}
          loading="eager"
          fetchpriority="high"
          class="w-6 h-6"
        />
        <span class="hidden sm:inline"><small>Instagram</small></span>
      </a>
    </div>
    <div class="py-2 px-1 sm:py-4 sm:px-2">
      <a
        href="https://wa.me/56974587354?text=Hola!%20me%20puedes%20entregar%20más%20información%20sobre%20la%20venta%20de%20huevos."
        target="_blank"
        class="flex flex-col justify-center items-center cursor-pointer"
        style="color: #432918"
      >
        <Image
          src={wsp}
          alt="Whatsapp ventas"
          width={24}
          height={24}
          loading="eager"
          fetchpriority="high"
          class="w-6 h-6"
        />
        <span class="hidden sm:inline"><small>Whatsapp</small></span>
      </a>
    </div>
    <div class="py-2 px-1 sm:py-4 sm:px-2">
      <a
        href="https://maps.app.goo.gl/D2eX6zAxU5TttWGX7"
        target="_blank"
        class="flex flex-col justify-center items-center cursor-pointer"
        style="color: #432918"
      >
        <Image
          width={24}
          height={24}
          src={map}
          alt="Ubicación"
          loading="eager"
          fetchpriority="high"
          class="w-6 h-6"
        />
        <span class="hidden sm:inline"><small>Ubicación</small></span>
      </a>
    </div>
  </div>
</header>
