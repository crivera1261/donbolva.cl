---
import { Image } from "astro:assets";
import logo from "@assets/logo.png";
import phone from "@assets/icons/whatsapp.svg";
import mail from "@assets/icons/mailPlus.svg";
import instagram from "@assets/icons/instagram.svg";
import map from "@assets/icons/map.svg";
---

<header
  class="flex justify-between w-[100%] h-3 pl-18 pr-18"
  style="background-color:#FCFCFC"
>
  <!-- logo -->
  <div class="flex">
    <a href="/">
      <Image
        alt="logo"
        src={logo}
        width="100"
        height="350"
        decoding="async"
        loading="eager"
        fetchpriority="high"
      />
    </a>
  </div>
  <!-- Acciones -->
  <div class="flex">
    <div class="py-4 px-2">
      <a
        href="https://www.instagram.com/donbolva_distribuidora?igsh=Z3hqMzc5bXZxNjA1"
        target="_blank"
        class="flex flex-col justify-center items-center cursor-pointer"
        style="color: #432918"
      >
        <Image
          src={instagram}
          alt="fono"
          width={20}
          height={40}
          loading="eager"
          fetchpriority="high"
        />
        <span><small>Instagram</small></span>
      </a>
    </div>
    <div class="py-4 px-2">
      <a
        href="https://wa.me/56989010231?text=Hola!%20me%20puedes%20entregar%20más%20información%20sobre%20la%20venta%20de%20huevos."
        target="_blank"
        class="flex flex-col justify-center items-center cursor-pointer"
        style="color: #432918"
      >
        <Image
          src={phone}
          alt="fono"
          width={20}
          height={40}
          loading="eager"
          fetchpriority="high"
        />
        <span><small>Makita</small></span>
      </a>
    </div>
    <div class="py-4 px-2">
      <a
        href="https://wa.me/56933286948?text=Hola!%20me%20puedes%20entregar%20más%20información%20sobre%20la%20venta%20de%20huevos."
        target="_blank"
        class="flex flex-col justify-center items-center cursor-pointer"
        style="color: #432918"
      >
        <Image
          src={phone}
          alt="fono"
          width={20}
          height={40}
          loading="eager"
          fetchpriority="high"
        />
        <span><small>Elita</small></span>
      </a>
    </div>
    <div class="py-4 px-2">
      <a
        href="mailto:hablemos@donbolva.cl"
        target="_blank"
        class="flex flex-col justify-center items-center cursor-pointer"
        style="font-color: #432918"
      >
        <Image
          width={20}
          height={40}
          src={mail}
          alt="mail"
          loading="eager"
          fetchpriority="high"
        />
        <span><small>E-mail</small></span>
      </a>
    </div>
    <div class="py-4 px-2">
      <a
        href="https://maps.app.goo.gl/D2eX6zAxU5TttWGX7"
        target="_blank"
        class="flex flex-col justify-center items-center cursor-pointer"
        style="font-color: #432918"
      >
        <Image
          width={20}
          height={40}
          src={map}
          alt="mail"
          loading="eager"
          fetchpriority="high"
        />
        <span><small>Ubicación</small></span>
      </a>
    </div>
  </div>
</header>
