---
import { Image } from "astro:assets";
import logo from "@assets/logo.png";
import phone from "@assets/icons/whatsapp.svg";
import mail from "@assets/icons/mail.svg";
---

<div class="flex justify-between absolute z-12 w-[100%]" style="background-color:#FCFCFC">
  <!-- logo -->
  <div class="flex py-4 px-8 ml-10">
    <a href="/">
      <Image
        alt="logo"
        src={logo}
        width="100"
        height="350"
        decoding="async"
        loading="eager"
        fetchpriority="high"
      />
    </a>
  </div>
  <!-- Acciones -->
  <div class="flex py-8 px-2 w-min-7 justify-evenly mr-25">
    <div class="py-4 px-2 mr-6 flex justify-center items-center">
      <span> Hablemos en</span>
    </div>
    <div class="py-4 px-2">
      <a
        href="https://wa.me/56989010231?text=Hola!%20me%20puedes%20entregar%20más%20información%20sobre%20la%20venta%20de%20huevos."
        target="_blank"
        class="flex flex-col justify-center items-center"
      >
        <Image
          src={phone}
          alt="fono"
          width="20"
          height="40"
          loading="eager"
          fetchpriority="high"
        />
        <span><small>Makita</small></span>
      </a>
    </div>
    <div class="py-4 px-2">
      <a
        href="https://wa.me/56933286948?text=Hola!%20me%20puedes%20entregar%20más%20información%20sobre%20la%20venta%20de%20huevos."
        target="_blank"
        class="flex flex-col justify-center items-center"
      >
        <Image
          src={phone}
          alt="fono"
          width="20"
          height="40"
          loading="eager"
          fetchpriority="high"
        />
        <span><small>Elita</small></span>
      </a>
    </div>
    <div class="py-4 px-2">
      <a
        href="mailto:hablemos@donbolva.cl"
        target="_blank"
        class="flex flex-col justify-center items-center"
      >
        <Image
          width="20"
          height="40"
          src={mail}
          alt="mail"
          loading="eager"
          fetchpriority="high"
        />
        <span><small>E-mail</small></span>
      </a>
    </div>
  </div>
</div>
