---
import FormWithLoading from "../components/contact-form/contact";
---

<main>
  <div class="flex flex-col relative">
    <!-- Seccion slogan + imagen -->
    <div class="flex">
      <img
        src={"/home/landing_eggs.png"}
        class="flex pt-30 w-[100%]"
        loading="lazy"
        alt="Huevos"
        fetchpriority="high"
        loading="eager"
      />
      <div
        class="flex flex-col justify-center flex-start ml-2 absolute md:max-w-[35%] min-h-[100%] md:ml-12 sm:max-w-[100%] text-[8px] md:text-xl px-6 sm:px-0"
      >
        <div class="flex items-center justify-center">
          <h2 style="color: #432918">
            <b class="text-2xl">
              Hoy es un gran día <br />
              <span style="color:red">para disfrutar</span>
            </b>
          </h2>
        </div>
        <img
          src={"/home/landing_roosters.png"}
          loading="lazy"
          alt="Gallos"
          fetchpriority="high"
          loading="eager"
        />
      </div>
    </div>
    <!-- Seccion formulario -->
    <div
      class="flex absolute right-0 bottom-0 mr-25 max-w-xl mx-auto bg-white p-6 rounded shadow-md space-y-4"
    >
      <FormWithLoading client:visible />
    </div>
  </div>
</main>
