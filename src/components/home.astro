---
import landingEggs from "./../../public/home/landing_eggs.png";
import landingNoFalten from "./../../public/home/landing_no_falten.png";
import landingRoosters from "./../../public/home/landing_roosters.png";
import landingGrass from "./../../public/home/landing_grass.png";
import { Image } from "astro:assets";
---

<main class="flex relative min-h-[70dvh]">
   <!-- Seccion izquierda -->
  <div
    class="flex flex-col md:justify-center absolute md:max-w-[50%] min-h-[100%] md:ml-12 sm:max-w-[100%] text-xl px-6 sm:px-0"
  >
    <!-- Encabezado -->
      <header class="text-center mb-8">
        <h1 class="text-5xl text-left font-extrabold text-red-600 tracking-wider">¡Hoola!</h1>
        <p class="text-lg mt-2 bg-black text-white inline-block px-4 py-1 rounded-md">#quenotefaltenhuevos</p>
      </header>

      <!-- Título de sección -->
      <div class="flex justify-center items-center gap-6 mb-6 text-amber-900 text-xl font-semibold">
        <span>Tipo</span>
        <svg class="w-8 h-8 text-amber-500" viewBox="0 0 24 24" fill="currentColor">
          <path d="M12 2C8.13 2 5 5.13 5 9c0 5.25 7 13 7 13s7-7.75 7-13c0-3.87-3.13-7-7-7zm0 9.5c-1.38 0-2.5-1.12-2.5-2.5s1.12-2.5 2.5-2.5 2.5 1.12 2.5 2.5-1.12 2.5-2.5 2.5z"/>
        </svg>
        <span>Formato</span>
        <svg class="w-8 h-8 text-amber-500" viewBox="0 0 24 24" fill="currentColor">
          <path d="M12 2C8.13 2 5 5.13 5 9c0 5.25 7 13 7 13s7-7.75 7-13c0-3.87-3.13-7-7-7zm-1 11h2v-2h-2v2zm0-4h2V7h-2v2zm0-4h2V3h-2v2z"/>
        </svg>
        <span class="text-sm">COLOR / BLANCO</span>
      </div>

      <!-- Tarjetas de productos -->
      <div class="bg-amber-800 p-6 rounded-xl shadow-lg mb-8">
        <div class="grid grid-cols-1 sm:grid-cols-2 md:grid-cols-5 gap-4">
          {[
            {
              tipo: 'Super super extra',
              peso: '73-105 grs.',
              unidades: ['180', '30', '20', '12', '6']
            },
            {
              tipo: 'Super extra',
              peso: '61-68 grs.',
              unidades: ['180', '30', '20', '12', '6']
            },
            {
              tipo: 'Extra',
              peso: '54-61 grs.',
              unidades: ['180', '30', '20', '12', '6']
            },
            {
              tipo: 'Primera',
              peso: '47-54 grs.',
              unidades: ['180', '30', '20', '12', '6']
            },
            {
              tipo: 'Segunda',
              peso: '40-47 grs.',
              unidades: ['180', '30', '20', '12', '6']
            }
          ].map((item) => (
            <div class="bg-amber-200 p-4 rounded-lg border border-amber-400 shadow-sm transition-transform hover:scale-105">
              <h3 class="font-bold text-amber-900">{item.tipo}</h3>
              <ul class="mt-2 text-xs text-amber-800 space-y-1">
                {item.unidades.map((u) => (
                  <li>{u} Unidades</li>
                ))}
              </ul>
              <div class="mt-3 bg-red-600 text-white text-xs font-semibold px-2 py-1 rounded">
                Peso unitario<br /><span class="text-sm">{item.peso}</span>
              </div>
            </div>
          ))}
        </div>
      </div>

      <!-- Notas importantes -->
      <div class="text-left text-sm text-gray-600 mb-6">
        <p><strong>*Todos los huevos que comercializamos son orgánicos, sin preservantes.</strong></p>
        <p><strong>*Su duración máxima es de 45 días.</strong></p>
      </div>
  </div>
  <!-- Seccion derecha -->
  <div
    class="flex flex-col md:flex-end max-w-[50%] md:max-w-[50%] absolute right-0 bottom-0 mr-25"
  >
    <div class="text-center py-12 px-4">
  <!-- Título principal -->
  <h2 class="text-3xl md:text-4xl font-bold mb-6 leading-tight">
    <span class="text-black">Hoy es un</span>
    <span class="text-red-600"> buen momento</span>
    <br />
    <span class="text-black">para disfrutar un</span>
    <span class="text-amber-900"> buen huevo</span>
  </h2>

  <!-- Flecha hacia abajo -->
  <div class="flex justify-center items-center my-6">
    <svg class="w-12 h-12 text-black" fill="currentColor" viewBox="0 0 24 24">
      <path d="M12 5l7 7H5l7-7z"/>
    </svg>
  </div>

  <!-- Botón de pedido -->
  <a
    href="/contact"
    target="_blank"
    class="inline-block bg-black text-white font-extrabold py-3 px-8 rounded-md text-lg hover:bg-gray-800 transition-colors shadow-md"
  >
    Haz tu pedido aquí
  </a>

  <!-- Texto informativo -->
  <p class="mt-12 text-sm text-center text-gray-700 max-w-xl mx-auto">
    En Don Bolva Distribuidora ponemos nuestros esfuerzos en fomentar la reutilización por ello invitamos a nuestros clientes a traer sus bandejas en sus próximas compras.
  </p>
  </div>
</main>
